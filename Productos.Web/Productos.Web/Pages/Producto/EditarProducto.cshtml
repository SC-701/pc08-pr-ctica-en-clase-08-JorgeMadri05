@page
@model Productos.Web.Pages.Producto.EditarProductoModel
@{
}
<h1>Editar Producto</h1>
<div class="container">
    <div class="col-xl col-lg-6 col-md-8 col-sm-10 mx-auto">
        <form method="post">
            <div class="form-group">
                <label for="categorias" class="form-label">Categoría</label>
                <select asp-for="categoriaSeleccionada" class="form-select" asp-items="Model.categorias" id="categorias" onchange="cargarSubCategorias()">
                    <option value="">Seleccione una categoría</option>
                </select>
            </div>
            <div class="form-group">
                <label for="subCategorias" class="form-label">Subcategoría</label>
                <select asp-for="subCategoriaSeleccionada" class="form-select" asp-items="Model.subCategorias" id="subCategorias">
                    <option value="">Seleccione una subcategoría</option>
                </select>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="producto.Nombre"></label>
                <input class="form-control" asp-for="producto.Nombre">
                <span class="text-danger" asp-validation-for="producto.Nombre"></span>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="producto.Descripcion"></label>
                <textarea class="form-control" asp-for="producto.Descripcion" rows="3"></textarea>
                <span class="text-danger" asp-validation-for="producto.Descripcion"></span>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="producto.Precio"></label>
                <input class="form-control" asp-for="producto.Precio" type="number" step="0.01">
                <span class="text-danger" asp-validation-for="producto.Precio"></span>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="producto.Stock"></label>
                <input class="form-control" asp-for="producto.Stock" type="number" step="1">
                <span class="text-danger" asp-validation-for="producto.Stock"></span>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="producto.CodigoBarras"></label>
                <input class="form-control" asp-for="producto.CodigoBarras">
                <span class="text-danger" asp-validation-for="producto.CodigoBarras"></span>
            </div>
            <div class="text-danger" asp-validation-summary="All"></div>
            <div class="form-group mt-3">
                <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                <input type="submit" value="Guardar Cambios" class="btn btn-success">
            </div>
            <input type="hidden" asp-for="producto.Id">
            <input type="hidden" asp-for="producto.Categoria" />
            <input type="hidden" asp-for="producto.SubCategoria" />
        </form>
    </div>
</div>

@section Scripts {
    <script>
        async function cargarSubCategorias() {
            const categoriaId = document.getElementById("categorias").value;
            if (!categoriaId) {
                return;
            }
            try {
                const respuesta = await fetch(`?handler=ObtenerSubCategorias&categoriaId=${categoriaId}`);
                const subCategorias = await respuesta.json();
                const subCategoriasSelect = document.getElementById("subCategorias");
                subCategoriasSelect.innerHTML = '<option value="">Seleccione una subcategoria</option>';
                subCategorias.forEach(subCategoria => {
                    const option = document.createElement("option");
                    option.value = subCategoria.id;
                    option.textContent = subCategoria.nombre;
                    subCategoriasSelect.appendChild(option);
                });
            } catch (error) {
                console.error("Error obteniendo subcategorias", error);
            }
        }
    </script>
}