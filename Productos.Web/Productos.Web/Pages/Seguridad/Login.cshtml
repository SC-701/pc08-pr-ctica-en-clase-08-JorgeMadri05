@page
@model Productos.Web.Pages.Seguridad.LoginModel
@{
}

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="card shadow-sm">
                    <div class="card-body p-4">

                        <div class="text-center mb-4">
                            <h3 class="fw-normal">Iniciar Sesión</h3>
                            <p class="text-muted small">Ingresa tus credenciales</p>
                        </div>

                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Correo electrónico</label>
                                <input type="email" class="form-control" asp-for="loginInfo.CorreoElectronico"
                                       placeholder="Ejem: ycorreo@ejemplo.com">
                                <span asp-validation-for="loginInfo.CorreoElectronico" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Contraseña</label>
                                <input type="password" class="form-control" asp-for="loginInfo.Password" />
                                <span asp-validation-for="loginInfo.Password" class="text-danger small"></span>
                            </div>

                            @if (Model.token is not null && Model.token.ValidacionExitosa == false)
                            {
                                <div class="alert alert-danger py-2" role="alert">
                                    Correo o contraseña incorrectos
                                </div>
                            }

                            <button type="submit" class="btn btn-primary w-100 mt-3">Ingresar</button>
                        </form>

                        <hr class="my-4">

                        <div class="text-center small">
                            <a asp-page="./Registrar" class="text-decoration-none me-3">Registrarse</a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>

</body>

